# Server
PORT=5000
NODE_ENV=development

# Database
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/finance_dashboard
# MongoDB Atlas (uncomment and replace if using cloud)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/finance_dashboard?retryWrites=true&w=majority

# JWT
# Replace this with a long random string in production (min 32 chars)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_strong_random_secret_here_min_32_characters
JWT_EXPIRES_IN=7d
